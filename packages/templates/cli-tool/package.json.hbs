{
  "name": "{{projectName}}",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "packageManager": "{{packageManager}}@{{packageManagerVersion}}",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "{{projectName}}": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "node --test",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@clack/prompts": "^0.9"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@types/node": "^22",
    "eslint": "^9",
    "tsup": "^8",
    "typescript": "^5",
    "typescript-eslint": "^8"
  }
}
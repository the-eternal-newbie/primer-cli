{
  "name": "@monomit/primer-workspace",
  "private": true,
  "keywords": [
    "ai",
    "cli",
    "scaffold",
    "cursor",
    "claude",
    "devtools",
    "typescript",
    "agentic"
  ],
  "description": "scaffold AI-ready projects with pre-configured agent conventions",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean"
  },
  "devDependencies": {
    "turbo": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"],
    "autoInstallPeers": true
  }
}